    {
      "name": "List quizzes (seeded user)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/quizzes/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "quizzes",
            ""
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const quizzes = pm.response.json();",
              "",
              "pm.test('returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('returns the seeded quiz with full fields', function () {",
              "  pm.expect(quizzes).to.have.lengthOf.at.least(1);",
              "  const quiz = quizzes[0];",
              "  pm.expect(quiz).to.have.all.keys(",
              "    'id', 'title', 'description', 'created_at',",
              "    'updated_at', 'video_url', 'questions'",
              "  );",
              "  pm.collectionVariables.set('quizId', quiz.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get quiz detail",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/quizzes/{{quizId}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "quizzes",
            "{{quizId}}",
            ""
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const quiz = pm.response.json();",
              "",
              "pm.test('returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('returns the requested quiz with its questions', function () {",
              "  pm.expect(String(quiz.id)).to.eql(String(pm.collectionVariables.get('quizId')));",
              "  pm.expect(quiz.questions).to.have.lengthOf.at.least(1);",
              "  pm.expect(quiz.questions[0]).to.include.all.keys(",
              "    'question_title', 'question_options', 'answer'",
              "  );",
              "});"
            ]
          }
        }
      ]
    },
