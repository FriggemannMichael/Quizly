            "type": "text/javascript",
            "exec": [
              "const quiz = pm.response.json();",
              "",
              "pm.test('returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('persists the partial update', function () {",
              "  pm.expect(quiz.title).to.eql('Updated by API smoke test');",
              "  pm.expect(quiz.description).to.eql('Partial update through Postman.');",
              "});"
            ]
          }
        }
      ]
    },
