{
  "info": {
    "_postman_id": "4fe0b6b8-8a67-4b57-8f82-6f76084db59c",
    "name": "Quizly API Smoke Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('username')) {",
          "  const suffix = `${Date.now()}_${Math.floor(Math.random() * 100000)}`;",
          "  pm.collectionVariables.set('username', `ci_user_${suffix}`);",
          "  pm.collectionVariables.set('email', `ci_user_${suffix}@example.com`);",
          "  pm.collectionVariables.set('password', 'Str0ng-test-pass!');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "seededUsername",
      "value": "postman_smoke"
    },
    {
      "key": "seededPassword",
      "value": "Postman-Sm0ke-2026!"
    }
  ],
  "item": [
    {
      "name": "Register user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"confirmed_password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/register/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "register",
            ""
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 201 Created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('returns registration detail', function () {",
              "  pm.expect(pm.response.json()).to.eql({",
              "    detail: 'User created successfully!'",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Login user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/login/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "login",
            ""
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "const setCookieHeaders = pm.response.headers",
              "  .all()",
              "  .filter((header) => header.key.toLowerCase() === 'set-cookie')",
              "  .map((header) => header.value)",
              "  .join('; ');",
              "",
              "pm.test('returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('returns logged-in user payload', function () {",
              "  pm.expect(body.detail).to.eql('Login successfully!');",
              "  pm.expect(body.user.username).to.eql(pm.collectionVariables.get('username'));",
              "  pm.expect(body.user.email).to.eql(pm.collectionVariables.get('email'));",
              "});",
              "",
              "pm.test('sets auth cookies', function () {",
              "  pm.expect(setCookieHeaders).to.include('access_token=');",
              "  pm.expect(setCookieHeaders).to.include('refresh_token=');",
              "  pm.expect(setCookieHeaders).to.include('HttpOnly');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Refresh token",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/token/refresh/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "token",
            "refresh",
            ""
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const setCookieHeaders = pm.response.headers",
              "  .all()",
              "  .filter((header) => header.key.toLowerCase() === 'set-cookie')",
              "  .map((header) => header.value)",
              "  .join('; ');",
              "",
              "pm.test('returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('returns refresh detail', function () {",
              "  pm.expect(pm.response.json().detail).to.eql('Token refreshed');",
              "});",
              "",
              "pm.test('sets a fresh access token cookie', function () {",
              "  pm.expect(setCookieHeaders).to.include('access_token=');",
              "  pm.expect(setCookieHeaders).to.include('HttpOnly');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List quizzes (fresh user)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/quizzes/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "quizzes",
            ""
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 200 OK via cookies', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('returns an empty list for a new user', function () {",
              "  pm.expect(pm.response.json()).to.eql([]);",
              "});"
            ]
          }
        }
      ]
    },
    {
